# Production backend deployment configuration.
# Copy this to backend/.env.production and fill only through the approved secret-management path.

# Existing shared AWS/database infrastructure
DATABASE_URL=
DB_SECRET_ARN=
VPC_ID=
PVT_SUBNET1=
PVT_SUBNET2=
LAMBDA_SG=
RDS_SG=
AWS_REGION=us-east-1
COGNITO_USER_POOL_ID=
S3_DOCUMENTS_BUCKET=
S3_REGION=us-east-1
KMS_KEY_ID=

# Production environment and secret boundary
DEPLOY_ENVIRONMENT=production
FRONTEND_URL=https://assessments.savians.com
ASSESSMENT_SECRET_NAME=savians/assessment/production

# Email
EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_ENABLED=true
EMAIL_FROM=awsadmin@savians.com
EMAIL_REPLY_TO=contactus@savians.com
SES_FROM_EMAIL=awsadmin@savians.com
SES_REPLY_TO_EMAIL=contactus@savians.com
SES_REGION=us-east-1

# QuickBooks production
QB_ENVIRONMENT=production
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REFRESH_TOKEN=
QB_REALM_ID=
QB_WEBHOOK_VERIFIER_TOKEN=
QB_SERVICE_ITEM_ID_TAX_ASSESSMENT=
QB_MINOR_VERSION=75
QB_BASE_URL=https://quickbooks.api.intuit.com/v3
